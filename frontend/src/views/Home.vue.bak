          </div>
          <div class="dest-item" v-for="d in destinations" :key="'r'+d.name">
            <img :src="d.img" :alt="d.name" @error="e=>e.target.style.display='none'">
            <div class="dest-overlay" />
            <div class="dest-label"><span>{{ d.tag }}</span><strong>{{ d.name }}</strong></div>
          </div>
