<script setup>
import { ref, onMounted } from 'vue'
import { useRouter } from 'vue-router'
import { ShieldCheck, Globe2, Sofa, Utensils, Smartphone, ArrowRight, ArrowUpRight } from 'lucide-vue-next'

const router = useRouter()

const promos = ref([
  { route: '天津-中国香港', date: '2024/06/01 - 2024/09/30', cabin: '经济舱往返', price: '1,398', from: '天津', to: '香港', img: 'https://images.unsplash.com/photo-1540206351-d6465b3ac5c1?auto=format&fit=crop&w=800&q=80' },
  { route: '天津-曼谷',     date: '2024/06/01 - 2024/09/30', cabin: '经济舱往返', price: '5,541', from: '天津', to: '曼谷', img: 'https://images.unsplash.com/photo-1545569341-9eb8b30979d9?auto=format&fit=crop&w=800&q=80' },
  { route: '天津-普吉',     date: '2024/06/01 - 2024/09/30', cabin: '经济舱往返', price: '1,303', from: '天津', to: '普吉', img: 'https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?auto=format&fit=crop&w=800&q=80' },
])

const destinations = [
  { tag: '热带天堂', name: '三亚', img: 'https://images.unsplash.com/photo-1544885935-98dd03d09034?auto=format&fit=crop&w=640&q=80' },
  { tag: '天府之国', name: '成都', img: 'https://images.unsplash.com/photo-1565099824688-e93eb20fe622?auto=format&fit=crop&w=640&q=80' },
  { tag: '霓虹都市', name: '东京', img: 'https://images.unsplash.com/photo-1540959733332-eab4deabeeaf?auto=format&fit=crop&w=640&q=80' },
  { tag: '沙漠明珠', name: '迪拜', img: 'https://images.unsplash.com/photo-1512453979798-5ea904ac6605?auto=format&fit=crop&w=640&q=80' },
  { tag: '浪漫之都', name: '巴黎', img: 'https://images.unsplash.com/photo-1502602898657-3e91760cbb34?auto=format&fit=crop&w=640&q=80' },
]

onMounted(() => {
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible') })
  }, { threshold: 0.1 })
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el))
})
</script>

<template>
  <div class="home">

    <!-- ==================== HERO ==================== -->
    <header class="hero">
