          <div class="val-card reveal card-hover mt-12">
            <Utensils :size="32" class="val-icon" />
            <h3>高空美馔</h3>
            <p>米其林团队打造，万米高空也能享受味蕾盛宴。</p>
          </div>
          <div class="val-card reveal card-hover">
            <Smartphone :size="32" class="val-icon" />
            <h3>数字服务</h3>
            <p>一键值机、实时追踪、智能推荐。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== 精选航线优惠 ==================== -->
    <section class="promos">
      <div class="section-inner">
        <div class="flex items-center gap-6 mb-16 reveal">
          <div class="gold-line" />
          <h2 class="title-l" style="color:var(--cream)">精选航线优惠</h2>
        </div>
        <div class="promo-grid">
          <div v-for="(p,i) in promos" :key="i" class="promo-card reveal" :class="{ 'mt-16': i===1 }" :style="{ transitionDelay: `${i*0.15}s` }">
            <div class="promo-img-wrap">
              <img :src="p.img" :alt="p.route" class="promo-img" @error="e=>e.target.style.display='none'">
            </div>
            <div class="promo-info">
              <div>
                <p class="promo-route">{{ p.from }} → {{ p.to }}</p>
                <p class="promo-price">¥{{ p.price }} <small>起</small></p>
              </div>
              <div class="promo-arrow">
                <ArrowUpRight :size="16" />
              </div>
